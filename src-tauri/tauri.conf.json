{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Couturier",
  "version": "0.1.0",
  "identifier": "com.couturier.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Couturier",
        "width": 620,
        "height": 420,
        "minWidth": 520,
        "minHeight": 360,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
