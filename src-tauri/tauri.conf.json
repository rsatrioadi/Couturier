{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Couturier",
  "version": "0.1.0",
  "identifier": "com.couturier.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Couturier",
        "width": 640,
        "height": 460,
        "minWidth": 640,
        "minHeight": 460,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 9, "y": 15 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
